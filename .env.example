# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=events_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://app_user:changeme@localhost:5432/events_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_EVENTS_TOPIC=events
KAFKA_AI_RESULTS_TOPIC=ai-results
KAFKA_DLQ_TOPIC=events-dlq
KAFKA_CONSUMER_GROUP=event-workers

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ─── AI Service ──────────────────────────────────────────────────────────────
AI_MODEL_NAME=distilbert-base-uncased
AI_MODEL_VERSION=v1
AI_MODEL_DIR=./models

# ─── Observability ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-event-platform
PROMETHEUS_PORT=9090
